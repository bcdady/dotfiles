#!/usr/bin/bash
# ~/.profile: executed by the command interpreter for login shells.
# This file is not read by bash(1), if ~/.bash_profile or ~/.bash_login
# exists.
# see /usr/share/doc/bash/examples/startup-files for examples.
# the files are located in the bash-doc package.

# the default umask is set in /etc/profile; for setting the umask
# for ssh logins, install and configure the libpam-umask package.
#umask 022

# Auth tokens — source early so GUI apps (Zed, etc.) inherit them
for _sh in "$HOME/.config/shell"/*-token.sh; do
  [ -f "$_sh" ] && . "$_sh"
done
unset _sh

{{- if eq .chezmoi.os "darwin" }}
# if running zsh
if [ -n "$ZSH_VERSION" ]; then
    # include .zhrc if it exists
    if [ -f "$HOME/.zshrc" ]; then
        . "$HOME/.zshrc"
    fi
fi
{{- else if eq .chezmoi.os "linux" }}
# AWS environment (inherited by GUI apps and all subprocesses)
export AWS_PROFILE=dev
export AWS_DEFAULT_REGION=us-west-2
export AWS_CLI_AUTO_PROMPT=on-partial
export AWS_RETRY_MODE=adaptive

# if running bash
if [ -n "$BASH_VERSION" ]; then
    # include .bashrc if it exists
    if [ -f "$HOME/.bashrc" ]; then
        . "$HOME/.bashrc"
    fi
fi
{{- end }}

# set PATH so it includes user's bin if it exists
if [ -d "$HOME/bin" ]; then
    PATH="$HOME/bin:$PATH"
fi

# set PATH so it includes user's local bin if it exists
if [ -d "$HOME/.local/bin" ]; then
    PATH="$HOME/.local/bin:$PATH"
fi

{{- if eq .chezmoi.os "darwin" }}
test -e "${HOME}/.iterm2_shell_integration.bash" && source "${HOME}/.iterm2_shell_integration.bash"
{{- end }}
# load cargo env, if it exists
if [ -f "$HOME/.cargo/env" ]; then
    . "$HOME/.cargo/env"
fi
