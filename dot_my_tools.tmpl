#!/bin/bash

{{- if eq .chezmoi.os "linux" }}
# Skip HSTR when using Kiro - it has its own history management
if [[ "$TERM_PROGRAM" != "WarpTerminal" ]] && [[ "$TERM_PROGRAM" != "kiro" ]]; then
  alias hh=hstr
  shopt -s histappend
  export HISTCONTROL=ignoreboth
  export HISTFILESIZE=10000
  export HISTIGNORE='rm *:history*:printenv*'
  export HISTSIZE=${HISTFILESIZE}
  export HSTR_CONFIG=hicolor
  export PROMPT_COMMAND="history -a; history -n; ${PROMPT_COMMAND}"
  if [[ $- =~ .*i.* ]]; then bind '"\C-r": "\C-a hstr -- \C-j"'; fi
  if [[ $- =~ .*i.* ]]; then bind '"\C-xk": "\C-a hstr -k \C-j"'; fi
fi
{{- end }}

# Add Krew to PATH
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

# activate mise via shims (near-instant vs ~46ms for hook mode)
# run 'mise activate bash' in a shell if you need auto-switching per-directory
eval "$(~/.local/bin/mise activate bash --shims)"

# Ensure critical global tools (MCP runtimes, etc.) are installed.
# Runs in background to avoid blocking shell startup.
_mise_ensure_globals() {
  local missing=0
  for tool in bun uv node opencode; do
    mise which "$tool" &>/dev/null || missing=1
  done
  if [[ $missing -eq 1 ]]; then
    mise install --yes &>/dev/null
  fi
}
_mise_ensure_globals &
disown

# Skip homebrew maintenance in Kiro to speed up shell startup
[[ "$TERM_PROGRAM" != "kiro" ]] && [[ -f "${HOME}/.tools/homebrew" ]] && bash "${HOME}/.tools/homebrew"

# turn on git cli completion, if not already provided in Warp terminal
# shellcheck disable=SC1091
test "$TERM_PROGRAM" = "WarpTerminal" || source /usr/share/bash-completion/completions/git

# aws cli autocomplete, with aws installed via mise
if command -v aws >/dev/null 2>&1; then
  test "$TERM_PROGRAM" = "WarpTerminal" || complete -C "$(mise which aws)" aws
fi

# create jwt-decode tool / function
jwt-decode() {
  jq -R 'split(".") |.[0:2] | map(@base64d) | map(fromjson)' <<<$1
}

# bw node error message workaround
# https://github.com/bitwarden/clients/issues/6689#issuecomment-1787609205
alias bw='NODE_OPTIONS="--no-deprecation" bw'

# Lazy-load Bitwarden - only check when needed
bw-check() {
  test "$(command -v bw)" || {
    echo 'Bitwarden (bw command) Not Found'
    return 1
  }
  BW_STATUS=$(bw status | jq -r .status 2>/dev/null)
  echo "Bitwarden Status: ${BW_STATUS}"
  [[ "$BW_STATUS" == "unlocked" ]] || echo "Run 'bw unlock' to unlock vault"
}


# echo ''
{{- if eq .chezmoi.os "linux" }}
# configure vpn aliases for CLI on linux

# OpenVPN CLI
# shellcheck disable=SC2139
alias vpn="$(command -v openvpn3)"
vpnprofile='subsplash_pdx'
alias vpnc='vpn session-start -c $vpnprofile &> /dev/null && vpn sessions-list'
alias vpnd='vpn session-manage -D --config $vpnprofile' # $(vpn sessions-list | grep Path | head -n 1 | cut -d ":" -f2 | tr -d [:space:])'
alias vpns='vpn sessions-list'

# VPN status check - run 'vpns' to check status

# Skip starship in Kiro - it manages its own prompt
if [[ "$TERM_PROGRAM" != "WarpTerminal" ]] && [[ "$TERM_PROGRAM" != "kiro" ]]; then
  command -v starship >/dev/null 2>&1 || curl -sS https://starship.rs/install.sh | sh
  eval "$(starship init bash)"
fi
{{- end }}

# Update kubeconfig on demand (was ~2.7s of network calls on every shell startup)
update-kubeconfig() {
  for cluster in $(aws eks list-clusters --query 'clusters[*]' --output text 2>/dev/null); do
    aws eks update-kubeconfig --name "${cluster}" >/dev/null 2>&1
  done
  echo "kubeconfig updated"
}

function getconfig() {
  kubectl exec "$(kubectl get pods --namespace app-"${1}" -o name | head -n 1)" --namespace app-"${1}" -c app-base-http -- cat /go/config/"${1}".json
}

# Lazy-load kubectl completion (~33ms deferred until first tab-complete)
_lazy_kubectl() {
  unset -f _lazy_kubectl
  source <(kubectl completion bash)
  complete -o default -F __start_kubectl kubectl
  complete -o default -F __start_kubectl k
}
if command -v kubectl >/dev/null 2>&1; then
  complete -F _lazy_kubectl kubectl
  complete -F _lazy_kubectl k
fi

# Enable terraform autocomplete
(command -v terraform >/dev/null 2>&1) && complete -C "$(mise which terraform)" terraform
