# Case-insensitive tab completion
set completion-ignore-case on

# Show all matches immediately when ambiguous (no double-tab)
set show-all-if-ambiguous on

# Color-code completions by file type (like ls)
set colored-stats on

# Append a trailing slash to completed directory names
set mark-directories on
set mark-symlinked-directories on

# Show common prefix first, then cycle through matches
set completion-prefix-display-length 2
